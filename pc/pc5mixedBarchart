def compute_beta_map(ds, pc_mode, start_pentad=13, end_pentad=60):
    pre_var = 'pre' if 'pre' in ds.data_vars else list(ds.data_vars)[0]
    precip = ds[pre_var]

    precip_subset = precip.sel(pentad=slice(start_pentad, end_pentad)) * -1
    lats = precip_subset['lat'].values
    lons = precip_subset['lon'].values

    anomalies = (precip_subset - precip_subset.mean('year')).transpose('year', 'pentad', 'lat', 'lon')
    anomalies_2d = anomalies.values.reshape(-1, len(lats) * len(lons))

    valid_mask = ~np.isnan(anomalies_2d).all(axis=0)
    solver = Eof(anomalies_2d[:, valid_mask])
    pc = -solver.pcs(npcs=max(8, pc_mode), pcscaling=1)[:, pc_mode - 1]

    clean = anomalies_2d[:, valid_mask]
    betas = np.full(valid_mask.sum(), np.nan)
    for j in range(clean.shape[1]):
        y = clean[:, j]
        mask = ~np.isnan(y)
        if mask.sum() < 10:
            continue
        betas[j] = np.cov(pc[mask], y[mask])[0, 1] / np.var(pc[mask])

    beta_full = np.full(len(lats) * len(lons), np.nan)
    beta_full[valid_mask] = betas
    return beta_full.reshape(len(lats), len(lons)), lats, lons


def compute_ts(ds, pc_mode, start_pentad=13, end_pentad=60):
    pre_var = 'pre' if 'pre' in ds.data_vars else list(ds.data_vars)[0]
    precip = ds[pre_var]
    precip_subset = precip.sel(pentad=slice(start_pentad, end_pentad))

    beta_map_sel, lats, lons = compute_beta_map(ds, pc_mode, start_pentad, end_pentad)

    max_abs = np.nanmax(np.abs(beta_map_sel))
    dot_mask = (beta_map_sel < 0) & (np.abs(beta_map_sel) >= 0.50 * max_abs) & ~np.isnan(beta_map_sel)
    iy, ix = np.where(dot_mask)

    if iy.size == 0:
        return None, None, None

    precip_core = precip_subset.isel(
        lat=xr.DataArray(iy, dims='pts'),
        lon=xr.DataArray(ix, dims='pts')
    )
    ts_year = precip_core.mean(dim='pts')
    mean_ts = ts_year.mean(dim='year').values
    std_ts = ts_year.std(dim='year', ddof=1).values if ts_year.sizes.get('year', 0) >= 2 else np.zeros_like(mean_ts)
    pentads = np.arange(start_pentad, end_pentad + 1)
    return mean_ts, std_ts, pentads


