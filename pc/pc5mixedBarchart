def draw_map(fig, beta_map, lats, lons, shp_path=CHINA_SHP_PATH):
    ax = fig.add_axes(MAP_AX_POS, projection=proj)
    ax.set_extent([73, 136, 12, 54], crs=proj)
    ax.set_facecolor('#efefef')
    _draw_china_only(ax, linewidth=0.8, shp_path=shp_path)

    xticks = [75, 90, 105, 120, 135]
    yticks = [20, 30, 40, 50]
    ax.set_xticks(xticks, crs=proj)
    ax.set_yticks(yticks, crs=proj)
    ax.xaxis.set_major_formatter(LongitudeFormatter())
    ax.yaxis.set_major_formatter(LatitudeFormatter())
    ax.tick_params(axis='both', which='major', labelsize=12,
                   length=6, width=1, direction='out')
    add_south_china_sea_inset(ax, shp_path=shp_path)

    ax.plot(lon_data, lat_data, color='black', linewidth=2.0,
            linestyle='-', transform=proj, zorder=6)
    ax.scatter(lon_data, lat_data, color='black', s=40,
               edgecolors='black', linewidth=1.2, transform=proj, zorder=7)

    max_beta_abs = np.nanmax(np.abs(beta_map))

    lat_2d = np.tile(lats[:, np.newaxis], (1, len(lons)))
    lon_2d = np.tile(lons[np.newaxis, :], (len(lats), 1))
    north27_mask   = lat_2d >= 27.0
    southeast_mask = (lon_2d > 107.0) & (lat_2d < 30.0)
    valid_plot_mask = north27_mask & (~southeast_mask)

    shade_threshold = 0.10 * max_beta_abs
    # 0以下不填色：这里把 -0.5 到 0 这一档去掉，只保留 <= -0.5
    neg_mask = (beta_map <= -0.5) & (np.abs(beta_map) >= shade_threshold) & valid_plot_mask
    neg_plot = np.where(neg_mask, beta_map, np.nan)

    levels = np.array([-3.0, -2.5, -2.0, -1.5, -1.0, -0.5], dtype=float)
    cmap = get_deeper_green_cmap_r(len(levels) - 1)

    im = ax.contourf(
        lons, lats, neg_plot,
        cmap=cmap,
        extend='min',
        transform=proj,
        levels=levels,
        zorder=2
    )

    dot_mask = (beta_map < 0) & (np.abs(beta_map) >= 0.50 * max_beta_abs) & valid_plot_mask
    ax.contourf(
        lons, lats, dot_mask,
        levels=[0.5, 1.5],
        colors=['green'],
        alpha=0.4,
        transform=proj,
        zorder=3
    )
    ax.contourf(
        lons, lats, dot_mask,
        levels=[0.5, 1.5],
        colors='none',
        hatches=['...'],
        transform=proj,
        zorder=4
    )

    ellipse = Ellipse(
        xy=(np.mean(lon_data[16:25]), np.mean(lat_data[16:25])),
        width=10, height=6, angle=0,
        edgecolor='none', facecolor='green', alpha=0.5,
        transform=proj, zorder=5
    )
    ax.add_patch(ellipse)

    fig.text(MAP_AX_POS[0], MAP_AX_POS[1] + MAP_AX_POS[3] + 0.012,
             '(a) Reg Pre PC5',
             fontsize=24, fontweight='bold', va='bottom', ha='left')

    cax = fig.add_axes(CBAR_AX_POS)
    cbar = fig.colorbar(im, cax=cax, orientation='vertical', drawedges=True)
    cbar.set_ticks(levels)
    cbar.set_ticklabels(['3', '2.5', '2', '1.5', '1', '0.5'])
    cbar.ax.invert_yaxis()
    cbar.ax.tick_params(labelsize=10)
    if hasattr(cbar, 'dividers') and cbar.dividers is not None:
        cbar.dividers.set_color('#666666')
        cbar.dividers.set_linewidth(0.8)


def draw_ts(fig, mean_ts, std_ts, pentads):
    ax_ts = fig.add_axes(TS_AX_POS)

    bar_width = 0.6
    margin = bar_width * 1.5
    ax_ts.set_xlim(pentads[0] - margin, pentads[-1] + margin)

    ax_ts.bar(pentads, mean_ts, width=bar_width,
              color='#90c4e4', alpha=0.6, linewidth=0,
              zorder=2, label='Mean')

    ax_ts.fill_between(
        pentads,
        mean_ts - std_ts,
        mean_ts + std_ts,
        color='#d8cfee', alpha=0.35,
        linewidth=0, zorder=3, label='±1σ'
    )

    ref_val = np.nanmean(mean_ts)
    ax_ts.axhline(
        ref_val, color='red', linestyle='--',
        linewidth=1.8, zorder=4
    )

    rm = running_mean(mean_ts, 3)
    ax_ts.plot(
        pentads, rm, '-', linewidth=2.2, color='black',
        zorder=5, label='3-Pentad Running Mean'
    )

    ax_ts.set_xlabel('Pentad', fontsize=12)
    ax_ts.set_ylabel('Precipitation', fontsize=12)
    ax_ts.tick_params(axis='both', which='major', labelsize=12,
                      direction='out', length=6, width=1)
    ax_ts.grid(False)
    for spine in ax_ts.spines.values():
        spine.set_linewidth(1.0)

    title_y = MAP_AX_POS[1] + MAP_AX_POS[3] + 0.012
    fig.text(TS_AX_POS[0], title_y,
             '(b) Composite PC5',
             fontsize=24, fontweight='bold', va='bottom', ha='left')


def main(file_path=FILE_PATH, shp_path=CHINA_SHP_PATH):
    if not os.path.exists(file_path):
        raise FileNotFoundError(f"文件不存在: {file_path}")

    print("读取数据...")
    ds = xr.open_dataset(file_path)

    print("计算左图 beta_map (PC5)...")
    beta_map, lats, lons = compute_beta_map(ds, pc_mode=PC_TO_USE_MAP)

    print("计算右图时间序列 (PC5)...")
    mean_ts, std_ts, pentads = compute_ts(ds, pc_mode=PC_TO_USE_TS)

    print("绘图...")
    fig = plt.figure(figsize=FIG_SIZE, facecolor='white')

    draw_map(fig, beta_map, lats, lons, shp_path=shp_path)

    if mean_ts is not None:
        draw_ts(fig, mean_ts, std_ts, pentads)
    else:
        print("警告：未找到核心区域，右图跳过。")

    out_path = 'combined_figure_pc5_modified.png'
    fig.savefig(out_path, dpi=EXPORT_DPI, facecolor='white', bbox_inches='tight')
    print(f"已保存: {out_path}")
    plt.show()


if __name__ == "__main__":
    main()
