def running_mean(data, window):
    weights = np.ones(window) / window
    rm = np.convolve(data, weights, mode='valid')
    pad_len = window // 2
    return np.pad(rm, (pad_len, window - 1 - pad_len), 'constant', constant_values=np.nan)


def get_deeper_green_cmap_r(n_colors):
    n_colors = max(n_colors, 1)
    colors = plt.cm.Greens(np.linspace(0.92, 0.32, n_colors))
    cmap = ListedColormap(colors)
    cmap.set_under(plt.cm.Greens(0.99))
    cmap.set_over('white')   # 0以上不再填色
    return cmap


def _load_user_shp_records(shp_path=CHINA_SHP_PATH):
    if not os.path.exists(shp_path):
        raise FileNotFoundError(f"未找到国界 shp 文件: {shp_path}")
    reader = shapereader.Reader(shp_path)
    records = list(reader.records())
    if not records:
        raise ValueError(f"shp 文件中未读取到几何对象: {shp_path}")
    return records


def _draw_china_only(ax, linewidth=0.8, edgecolor='#a9a9a9', shp_path=CHINA_SHP_PATH):
    records = _load_user_shp_records(shp_path)
    geometries = [r.geometry for r in records if r.geometry is not None]
    ax.add_geometries(
        geometries, crs=proj,
        facecolor='white', edgecolor=edgecolor,
        linewidth=linewidth, zorder=1
    )


def _extract_scs_line_geometries(records):
    keyword_list = ['南海', '九段', '十段', '断续', '国界', '疆界',
                    'boundary', 'dash', 'u-shape']
    keyword_hits, line_geoms = [], []
    for rec in records:
        geom = rec.geometry
        if geom is None:
            continue
        geom_type = getattr(geom, 'geom_type', '')
        attrs = getattr(rec, 'attributes', {}) or {}
        attr_text = ' '.join(str(v) for v in attrs.values()).lower()
        if 'line' in geom_type.lower():
            line_geoms.append(geom)
            if any(k.lower() in attr_text for k in keyword_list):
                keyword_hits.append(geom)
    return keyword_hits if keyword_hits else line_geoms


def _draw_scs_dashed(ax, shp_path=CHINA_SHP_PATH, linewidth=0.9, color='#5f5f5f'):
    records = _load_user_shp_records(shp_path)
    scs_geoms = _extract_scs_line_geometries(records)
    if not scs_geoms:
        return
    clip_extent = box(104, 3, 125, 25)
    clipped = []
    for g in scs_geoms:
        try:
            part = g.intersection(clip_extent)
            if not part.is_empty:
                clipped.append(part)
        except Exception:
            pass
    if clipped:
        ax.add_geometries(
            clipped, crs=proj, facecolor='none',
            edgecolor=color, linewidth=linewidth,
            linestyle='--', zorder=3
        )


