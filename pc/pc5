def setup_map(ax, shp_path=CHINA_SHP_PATH):
    ax.set_extent([73, 136, 12, 54], crs=proj)
    ax.set_facecolor('#efefef')
    _draw_china_only(ax, linewidth=0.8, shp_path=shp_path)

    xticks = [75, 90, 105, 120, 135]
    yticks = [20, 30, 40, 50]
    ax.set_xticks(xticks, crs=proj)
    ax.set_yticks(yticks, crs=proj)
    ax.xaxis.set_major_formatter(LongitudeFormatter())
    ax.yaxis.set_major_formatter(LatitudeFormatter())
    ax.tick_params(axis='both', which='major', labelsize=12, length=6, width=1, direction='out')

    add_south_china_sea_inset(ax, shp_path=shp_path)


def main(file_path, shp_path=CHINA_SHP_PATH):
    if not os.path.exists(file_path):
        raise FileNotFoundError(f"文件不存在: {file_path}")

    beta_map, lats, lons = compute_beta_map(file_path, pc_mode=PC_TO_USE)
    fig, ax = plt.subplots(figsize=(10, 8), subplot_kw={'projection': proj})
    setup_map(ax, shp_path=shp_path)
    draw_track(ax)
    plot_pc5_negative(fig, ax, beta_map, lats, lons)

    save_path = r"C:\Users\DELL\Desktop\answer\regression_map.png"
    plt.savefig(save_path, dpi=300, bbox_inches='tight', facecolor='white', edgecolor='none')
    plt.tight_layout()
    plt.show()

    return beta_map


